<?xml version="1.0" encoding="UTF-8" ?>
<items>
    <resource dir="file:///android_asset/kr-script/miui" />
    <group id="thermal">
        <picker id="mi-thermal-local" reload="thermal"
            title="@string:mi_thermal_config"
            desc="@string:mi_thermal_config_desc"
            options-sh="pipe miui-thermal">
            <summary sh="run thermal_conf3/summary.sh" />
            <get>cat /data/vendor/thermal/config/thermal.current.ini 2>/dev/null || echo  ''</get>
            <set>run thermal_conf3/config.sh</set>
        </picker>
    </group>
    <group>
        <page title="@string:mi_joyose"
            activity="com.omarea.vtools/.activities.ActivityMiuiCloudProfile">
        </page>
    </group>
</items>